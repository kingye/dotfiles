{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",
    "target": "ES2022",
    "module": "commonjs",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "preserveConstEnums": true
  },
  "ts-node": {
    "files": true
  },
  "include": ["src/**/*.ts"]
}
