  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://localhost:6655/anthropic/v1",
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "tencent": {
      "options": {
        "baseURL": "https://api.lkeap.cloud.tencent.com/plan/v3",
        "apiKey": "{env:TENCENT_TOKEN_PLAN_KEY}"
      },
      "models": {
        "tc-code-latest": {
          "name": "Auto",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          },
          "limit": {
            "context": 196608,
            "output": 32768
          }
        },
        "hunyuan-2.0-instruct": {
