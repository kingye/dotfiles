{
  "$schema": "https://opencode.ai/config.json",
  "model": "ark/deepseek-v3.2",
  // "model": "ark/kimi-k2.5",
  "small_model": "SiliconFlow/Qwen/Qwen3-8B",
  // "model": "ark/glm-4-7",
