[
  // ========================================
  // Basic Vim Keybindings
  // ========================================

  // jk to escape (custom binding from your config)
  {
    "key": "j",
    "command": "extension.vim_escape",
    "when": "editorTextFocus && vim.active && !inDebugRepl && vim.mode == 'Insert' && editorLangId != 'magit'"
  },

  // Disable Ctrl+Z suspend
  {
    "key": "ctrl+z",
    "command": "-undo"
  },
  {
    "key": "ctrl+z",
    "command": ""
  },

  // ========================================
  // Window/Split Navigation (Ctrl+h/j/k/l)
  // ========================================

  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateLeft",
    "when": "vim.active && !inDebugRepl && !suggestWidgetVisible && !parameterHintsVisible"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown",
    "when": "vim.active && !inDebugRepl && !suggestWidgetVisible && !parameterHintsVisible"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp",
    "when": "vim.active && !inDebugRepl && !suggestWidgetVisible && !parameterHintsVisible"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.navigateRight",
    "when": "vim.active && !inDebugRepl && !suggestWidgetVisible && !parameterHintsVisible"
  },

  // Ctrl+l: Leave sidebar and focus editor
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "sideBarFocus && !inputFocus"
  },

  // Find in Files: Enter to move focus to results
  {
    "key": "enter",
    "command": "search.action.focusSearchList",
    "when": "inSearchEditor || searchViewletFocus && inputBoxFocus"
  },

  // Git View: Enter to move focus to file list
  {
    "key": "enter",
    "command": "list.focusDown",
    "when": "scmRepositoriesViewVisible && inputBoxFocus"
  },

  // ========================================
  // Additional Vim Enhancements
  // ========================================

  // Keep search centered
  {
    "key": "n",
    "command": "vim.remap",
    "when": "vim.mode == 'Normal'",
    "args": {
      "after": ["n", "z", "z"]
    }
  },
  {
    "key": "N",
    "command": "vim.remap",
    "when": "vim.mode == 'Normal'",
    "args": {
      "after": ["N", "z", "z"]
    }
  },

  // Better indenting in visual mode
  {
    "key": "<",
    "command": "vim.remap",
    "when": "vim.mode == 'Visual'",
    "args": {
      "after": ["<", "g", "v"]
    }
  },
  {
    "key": ">",
    "command": "vim.remap",
    "when": "vim.mode == 'Visual'",
    "args": {
      "after": [">", "g", "v"]
    }
  },

  // Move selected lines up/down
  {
    "key": "shift+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "vim.mode == 'Visual' && editorTextFocus"
  },
  {
    "key": "shift+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "vim.mode == 'Visual' && editorTextFocus"
  },

  // ========================================
  // Leader Key Mappings (Space) - Sidebar Navigation
  // ========================================
  // These work when focused on sidebars (Git, Explorer, Search, etc.)

  // Space + e: Always focus on Files view in Explorer (not Rust Dependencies)
  // Higher priority binding for Rust files to override rust-analyzer
  {
    "key": "space e",
    "command": "workbench.files.action.focusFilesExplorer",
    "when": "vim.mode == 'Normal' && !inputFocus && editorLangId == 'rust'"
  },
  // General binding for all other cases
  {
    "key": "space e",
    "command": "workbench.files.action.focusFilesExplorer",
    "when": "vim.mode == 'Normal' && !inputFocus"
  },

  // Space + e: Toggle sidebar visibility (close entire sidebar) when in sidebar
  {
    "key": "space o",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "sideBarFocus && !inputFocus"
  },

  // Space + g + g: Switch to Git from any sidebar
  {
    "key": "space g g",
    "command": "workbench.view.scm",
    "when": "sideBarFocus && !inputFocus"
  },

  // Space + s + g: Switch to Search from any sidebar
  {
    "key": "space s g",
    "command": "workbench.action.findInFiles",
    "when": "sideBarFocus && !inputFocus"
  },

  // ========================================
  // Panel Navigation (Ctrl+H/J/K/L from panels)
  // ========================================
  // Extend Ctrl+H/J/K/L navigation to work from terminal/problems/debug console

  // Ctrl+K: Move UP from panel to editor
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp",
    "when": "terminalFocus || panelFocus"
  },

  // Ctrl+J: Move DOWN from editor to panel
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown",
    "when": "editorFocus && !suggestWidgetVisible && !parameterHintsVisible"
  },

  // Ctrl+H: Move LEFT from panel
  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateLeft",
    "when": "terminalFocus || panelFocus"
  },

  // Ctrl+L: Move RIGHT from panel
  {
    "key": "ctrl+l",
    "command": "workbench.action.navigateRight",
    "when": "terminalFocus || panelFocus"
  },

  // ========================================
  // Panel Visibility Toggle
  // ========================================

  // Ctrl+/: Toggle bottom panel visibility (terminal, debug console, problems, etc.)
  {
    "key": "ctrl+/",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  {
    "key": "ctrl+p",
    "command": "workbench.action.togglePanel"
  },

  // ========================================
  // Quick Open Recent
  // ========================================

  // Ctrl+S S: Open recent files/workspaces dropdown
  {
    "key": "ctrl+s s",
    "command": "workbench.action.openRecent"
  },

  // ========================================
  // Git Pane (Lazygit-like shortcuts)
  // ========================================
  // These shortcuts work when focused on the Source Control view (Git pane)

  // c: Commit (opens commit message input)
  // First disable the default list type-to-search behavior
  {
    "key": "c",
    "command": "-list.find",
    "when": "listFocus && listSupportsFind"
  },
  {
    "key": "c",
    "command": "git.commit",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus"
  },

  // Additional Git shortcuts for better workflow
  {
    "key": "shift+c",
    "command": "git.commitAll",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus"
  },
  {
    "key": "a",
    "command": "git.stage",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus && !scmRepository"
  },
  {
    "key": "u",
    "command": "git.unstage",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus && !scmRepository"
  },
  {
    "key": "p",
    "command": "git.push",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus"
  },
  {
    "key": "shift+p",
    "command": "git.pull",
    "when": "sideBarVisible && activeViewlet == 'workbench.view.scm' && !inputFocus"
  }
]
