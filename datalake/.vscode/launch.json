{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "command": "npm run upload",
      "name": "upload",
      "request": "launch",
      "type": "node-terminal",
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "testcase",
      "type": "promptString",
      "description": "Describe your testcase",
      "default": "",
      "password": false
    },
    {
      "id": "testfile",
      "type": "promptString",
      "description": "Name your testfile",
      "default": "./tests/integration/**/*.test.ts",
      "password": false
    }
  ]
}
