###
//@name=retreiveUsages
// @certificate={{cert}}
// @certificate-key={{key}}
< {%
    const credentials = $xsenv.serviceCredentials({ name : "sfm-unified-metering" });
    request.variables.set("cert", credentials.certificate);
    request.variables.set("key", credentials.key);
    request.variables.set("endpoint", credentials.endpoints.syncRetrieval);
    request.variables.set("meteringAccountName", credentials.meteringAccount.name);
%}
GET {{endpoint}}/v2/accounts/{{meteringAccountName}}/namespaces/metering/datastreams/btp$1/events
Content-Type: application/json

