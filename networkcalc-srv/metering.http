// Call Unified Metering API

// @name=sendUsages-nc
POST http://localhost:4004/unified-metering/sendUsages
Content-Type: application/json
dwc-subaccount-id: c645be38-509d-4335-b0a3-bf772f0bbdf3
dwc-tenent: c645be38-509d-4335-b0a3-bf772f0bbdf2
Authorization: Basic BEM_ALL:Welcome1

{
    "usages" : [
       {
            "id": "c2214e4e-9629-42a0-8fbb-5d204c29c21b",
            "timestamp": "2025-05-21T01:30:00.339Z",
            "measure": {
                "id": "footprint-calculated",
                "value": 100
            }
        }
    ]
}

###
//@name=ingestUsages
// @certificate={{cert}}
// @certificate-key={{key}}
< {%
    const credentials = $xsenv.serviceCredentials({ name : "sfm-unified-metering" });
    request.variables.set("cert", credentials.certificate);
    request.variables.set("key", credentials.key);
    request.variables.set("endpoint", credentials.endpoints.usageIngestion);
    request.variables.set("meteringAccountName", credentials.meteringAccount.name);
%}
POST {{endpoint}}/v2/accounts/{{meteringAccountName}}/namespaces/metering/datastreams/btp$1/eventBatch
Content-Type: application/json

[
   {
        "id": "c2214e4e-9629-42a0-8fbb-5d204c29c21d",
        "timestamp": "2025-05-21T01:30:00.339Z",
        "consumer": {
            "region": "cf-eu20",
            "btp": {
                "environment": "CF",
                "subAccount": "c645be38-509d-4335-b0a3-bf772f0bbdf2"
            }
        },
        "product": {
            "service": {
                "id": "sustainability-footprint-management",
                "plan": "standard"
            }
        },
        "measure": {
            "id": "footprint-calculated",
            "value": 100
        }
    }
]

